# Public Base RPC for the hosted Vercel deploy. Replace with your own
# Alchemy/QuickNode key for production — public Base is rate-limited.
DAPPQL_DEFAULT_RPC_URL=https://mainnet.base.org

# IMPORTANT: do NOT set DAPPQL_PRIVATE_KEY or MNEMONIC on the hosted deploy.
# Hosted MCP must never sign transactions. Writes stay disabled by default.
